{{ $email := env "CHEZMOI_GIT_EMAIL" }}
{{ if not $email }}
{{   $email = promptStringOnce . "email" "Email address for Git commits" }}
{{ end }}
{{ $name := env "CHEZMOI_GIT_NAME" }}
{{ if not $name }}
{{   $name = promptStringOnce . "name" "Name for Git commits" }}
{{ end }}
{{ $env_type := env "CHEZMOI_ENV_TYPE" }}
{{ if not $env_type }}
{{   $env_type = promptStringOnce . "env_type" "Environment type (full/devcontainer)" }}
{{ end }}
{{ $virt_type := output "sh" "-c" "systemd-detect-virt 2>/dev/null || echo none" | trim }}
{{ $has_battery := output "sh" "-c" "ls /sys/class/power_supply/BAT* >/dev/null 2>&1 && echo true || echo false" | trim | eq "true" }}

[data]
    email = {{ $email | quote }}
    name = {{ $name | quote }}
    env_type = {{ $env_type | quote }}
    virt_type = {{ $virt_type | quote }}
    has_battery = {{ $has_battery }}
