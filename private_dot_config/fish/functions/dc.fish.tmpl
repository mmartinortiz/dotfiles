{{ if eq .env_type "full" -}}
function dc --description "devcontainer wrapper"
    set --local workspace (pwd)
    set --local mounts
    set --append mounts --mount "type=bind,source=$HOME/.config/nvim,target=/home/vscode/.config/nvim"
    set --append mounts --mount "type=bind,source=$HOME/.gitconfig,target=/home/vscode/.gitconfig"
    set --append mounts --mount "type=bind,source=$HOME/.config/opencode,target=/home/vscode/.config/opencode"

    if test -d $HOME/.claude
        set --append mounts --mount "type=bind,source=$HOME/.claude,target=/home/vscode/.claude"
    end
    if test -e $HOME/.claude.json
        set --append mounts --mount "type=bind,source=$HOME/.claude.json,target=/home/vscode/.claude.json"
    end
    if test -d $HOME/.local/share/opencode
        set --append mounts --mount "type=bind,source=$HOME/.local/share/opencode,target=/home/vscode/.local/share/opencode"
    end
    if test -d $HOME/.agents
        set --append mounts --mount "type=bind,source=$HOME/.agents,target=/home/vscode/.agents"
    end

    switch $argv[1]
        case -h --help ''
            echo "dc - devcontainer wrapper"
            echo ""
            echo "Usage: dc <command> [args]"
            echo ""
            echo "Commands:"
            echo "  up, u      Start container (remove existing)"
            echo "    --ssh      Mount ~/.ssh (up only)"
            echo "    --upgrade  Run devcontainer upgrade before up"
            echo "  upf, uf    Start fast (skip post-create, reuse container)"
            echo "  build, b   Build image"
            echo "  exec, e    Run command in container"
            echo "  sh         Interactive bash shell"
            echo "  fish       Interactive fish shell"
            echo "  stop, s    Stop container"
            echo "  down, d    Stop and delete container"
            echo ""
            echo "Examples:"
            echo "  dc up"
            echo "  dc up --ssh"
            echo "  dc exec cargo build"
            echo "  dc sh"
        case up u
            argparse 'ssh' 'upgrade' -- $argv[2..-1]
            or return
            if set --query _flag_ssh; and test -d $HOME/.ssh
                set --append mounts --mount "type=bind,source=$HOME/.ssh,target=/home/vscode/.ssh"
            end
            if set --query _flag_upgrade
                devcontainer upgrade --workspace-folder $workspace
                or return
            end
            devcontainer up $mounts --remove-existing-container --workspace-folder $workspace
        case upf uf
            devcontainer up $mounts --skip-post-create --workspace-folder $workspace
        case build b
            devcontainer build --workspace-folder $workspace
        case exec e
            devcontainer exec --workspace-folder $workspace $argv[2..-1]
        case sh
            devcontainer exec --workspace-folder $workspace bash
        case fish
            devcontainer exec --workspace-folder $workspace fish
        case stop s
            set --local container_id (docker ps --quiet --filter "label=devcontainer.local_folder=$workspace")
            if test -n "$container_id"
                docker stop $container_id
            else
                echo "No running devcontainer found for $workspace"
                return 1
            end
        case down d
            set --local container_id (docker ps --all --quiet --filter "label=devcontainer.local_folder=$workspace")
            if test -n "$container_id"
                docker rm --force $container_id
            else
                echo "No devcontainer found for $workspace"
                return 1
            end
        case '*'
            devcontainer $argv
    end
end
{{ end -}}
